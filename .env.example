# postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=yauli
POSTGRES_PORT=5432

# backend-api
BACKEND_API_PORT=8081
# Shared secret between backend-api and auth-service for the internal API.
INTERNAL_AUTH_SECRET=change-me
# backend-api calls auth-service over the private network when access changes
# need durable session revocation.
AUTH_SERVICE_URL=http://auth-service:8082
# Optional. When unset, /reports/ai returns cached reports only and reports
# cache misses as AI generation not configured.
OPENAI_API_KEY=
# Optional; backend-api defaults this when OPENAI_API_KEY is set.
OPENAI_MODEL=

# auth-service
AUTH_SERVICE_PORT=8082
# Signs/verifies JWT access tokens; shared between auth-service and
# backend-api.
JWT_SIGNING_SECRET=change-me
# Shared secret between trusted callers and auth-service, gating
# auth-service's /internal/auth/* routes (mint/logout/attach-family/session
# revocation) — without this, anyone with network reach to auth-service could
# mint access tokens or revoke sessions for known IDs.
FRONTEND_AUTH_SECRET=change-me
# Production email delivery. Local dev leaves these empty and logs magic links
# to auth-service stdout and scheduled report emails to backend-api stdout.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=
# Optional; use Mailgun's EU/test base URL if needed. Defaults to
# https://api.mailgun.net when empty.
MAILGUN_BASE_URL=

# frontend
FRONTEND_PORT=8080
# Unset (local dev) sends the yauli_session cookie without Secure and logs
# magic links to auth-service stdout. Set to "production" to require HTTPS
# and Mailgun email delivery.
ENV=
