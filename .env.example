# postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=yauli
POSTGRES_PORT=5432

# backend-api
BACKEND_API_PORT=8081
# Shared secret between backend-api and auth-service for the internal API.
# Not currently sent by anything — auth-service (PR6+) is what will send it.
INTERNAL_AUTH_SECRET=change-me

# auth-service
AUTH_SERVICE_PORT=8082

# frontend
FRONTEND_PORT=8080
